generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  supabaseId    String    @unique
  plan          Plan      @default(FREE)
  stripeCustomerId String? @unique
  stripeSubId   String?
  tripsThisMonth Int      @default(0)
  lastResetAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  trips         Trip[]
  savedFlights  SavedFlight[]
  savedHotels   SavedHotel[]
  tripCollaborations TripCollaborator[] @relation("tripCollaborations")
  sharedTrips   TripShare[] @relation("sharedTrips")
  ownedTeams    Team[]    @relation("teamOwner")
  teamMemberships TeamMember[] @relation("teamMemberships")

  @@map("users")
}

enum Plan {
  FREE
  PRO
  TEAMS
}

model Trip {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  destination String
  origin      String
  startDate   DateTime
  endDate     DateTime
  travelers   Int       @default(1)
  budget      String?
  style       String[]  // ["adventure", "food", "culture", "beach", "luxury"]
  status      TripStatus @default(DRAFT)

  aiItinerary Json?     // Full Claude-generated itinerary object
  userNotes   String?
  isPublic    Boolean   @default(false)
  shareToken  String?   @unique

  days        TripDay[]
  flights     TripFlight[]
  hotels      TripHotel[]
  shares      TripShare[]
  chatMessages TripChatMessage[]
  collaborators TripCollaborator[] @relation("collaborators")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("trips")
}

enum TripStatus {
  DRAFT
  PLANNED
  BOOKED
  COMPLETED
}

model TripDay {
  id          String    @id @default(cuid())
  tripId      String
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  dayNumber   Int
  date        DateTime
  title       String
  activities  Json[]    // Array of activity objects
  notes       String?

  @@map("trip_days")
}

model TripFlight {
  id          String    @id @default(cuid())
  tripId      String
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  type        FlightType
  airline     String
  flightNum   String?
  origin      String
  destination String
  departure   DateTime
  arrival     DateTime
  duration    Int       // minutes
  stops       Int       @default(0)
  price       Float
  currency    String    @default("USD")
  cabinClass  String    @default("economy")
  bookingUrl  String?
  serpData    Json?     // raw SerpAPI response

  @@map("trip_flights")
}

enum FlightType {
  OUTBOUND
  RETURN
}

model TripHotel {
  id          String    @id @default(cuid())
  tripId      String
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  name        String
  address     String
  city        String
  stars       Int?
  rating      Float?
  pricePerNight Float
  totalPrice  Float
  currency    String    @default("USD")
  checkIn     DateTime
  checkOut    DateTime
  imageUrl    String?
  bookingUrl  String    // Booking.com affiliate link
  bookingData Json?     // raw Booking.com response

  @@map("trip_hotels")
}

model SavedFlight {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data      Json
  createdAt DateTime @default(now())

  @@map("saved_flights")
}

model SavedHotel {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data      Json
  createdAt DateTime @default(now())

  @@map("saved_hotels")
}

model FlightPriceAlert {
  id              String    @id @default(cuid())
  email           String
  origin          String
  destination     String
  targetPrice     Float
  departureDate   DateTime?
  isActive        Boolean   @default(true)
  lastNotified    DateTime?
  lowestPrice     Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([email])
  @@index([isActive])
  @@map("flight_price_alerts")
}

model TripExpense {
  id          String    @id @default(cuid())
  tripId      String
  category    String    // "food", "transport", "accommodation", "entertainment", "shopping", "activities", "other"
  amount      Float
  description String?
  paidBy      String    // email or name of person who paid
  splitWith   String[]  @default([]) // list of people to split with
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tripId])
  @@map("trip_expenses")
}

model TripShare {
  id          String    @id @default(cuid())
  tripId      String
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("sharedTrips", fields: [userId], references: [id], onDelete: Cascade)
  shareToken  String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([shareToken])
  @@index([userId])
  @@map("trip_shares")
}

model TripChatMessage {
  id          String    @id @default(cuid())
  tripId      String
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  role        String    // "user" or "assistant"
  content     String
  createdAt   DateTime  @default(now())

  @@index([tripId])
  @@map("trip_chat_messages")
}

model TripCollaborator {
  id          String    @id @default(cuid())
  tripId      String
  trip        Trip      @relation("collaborators", fields: [tripId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("tripCollaborations", fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("viewer") // "viewer" or "editor"
  addedAt     DateTime  @default(now())

  @@unique([tripId, userId])
  @@index([userId])
  @@map("trip_collaborators")
}

model Team {
  id          String    @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User      @relation("teamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  
  members     TeamMember[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([ownerId])
  @@map("teams")
}

model TeamMember {
  id          String    @id @default(cuid())
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("teamMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("member") // "owner", "admin", "member"
  joinedAt    DateTime  @default(now())

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}
